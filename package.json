{
  "name": "weekly-work-review",
  "version": "1.0.0",
  "description": "项目看板 - 桌面端应用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win",
    "build:dir": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win --dir"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "echarts": "^5.6.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.kanban.weekly-work-review",
    "productName": "项目看板",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "home.html",
      "kanban.html",
      "Index.html",
      "usage.html",
      "calendar.html",
      "meeting.html",
      "data/**/*",
      "node_modules/echarts/dist/echarts.min.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "项目看板"
    }
  }
}
